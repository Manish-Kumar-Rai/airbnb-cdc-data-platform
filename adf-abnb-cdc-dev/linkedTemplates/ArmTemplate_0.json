					},
					{
						"name": "checkout_date",
						"type": "date"
					},
					{
						"name": "nights",
						"type": "int",
						"precision": 10
					},
					{
						"name": "lead_time_days",
						"type": "int",
						"precision": 10
					},
					{
						"name": "guests_adults",
